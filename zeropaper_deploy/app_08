async function sincronizarFirebase(op) {
  if (!session?.empresaId) return;
  try {
    const ctrl = new AbortController();
    setTimeout(() => ctrl.abort(), 8000);
    const token = await getValidToken();
    const headers = { 'Content-Type':'application/json' };
    if (token) headers['Authorization'] = `Bearer ${token}`;
    const url = `${FS_BASE()}/empresas/${session.empresaId}/ops?key=${FB.apiKey}`;

    // Flatten arrays (Firestore REST no soporta arrays con toFsDoc básico)
    const flat = {};
    for (const [k,v] of Object.entries(op)) {
      if (Array.isArray(v)) continue;
      flat[k] = v;
    }
    flat.logsJson    = JSON.stringify(op.logs    || []);
    flat.fotoIdsJson = JSON.stringify(op.fotoIds || []);

    const res = await fetch(url, {
      method: 'POST',
      headers,
      body: JSON.stringify(toFsDoc(flat)),
      signal: ctrl.signal
    });
    if (res.ok) {
      const data = await res.json();
      op._id = data.name?.split('/').pop(); // Guardar ID de Firestore para polling
      op.syncStatus = 'synced';
      await dbPut('ops', op);
    }
  } catch(e) { /* offline - op saved locally */ }
}

// Sync cola de pendientes al volver online
async function syncPendientes() {
  if (!session || !navigator.onLine) return;
  try {
    const ops = await dbGetAll('ops');
    const pendientes = ops.filter(o => o.syncStatus === 'pending' && o.empresaId === session.empresaId);
    for (const op of pendientes) {
      await sincronizarFirebase(op);
    }
  } catch(e) {}
}

