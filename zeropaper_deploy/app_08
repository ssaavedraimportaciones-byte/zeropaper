        `<button onclick="cambiarDepto('${d.id}')" style="background:none;border:1px solid var(--brd);border-radius:6px;padding:3px 8px;color:var(--mu);cursor:pointer;font-family:var(--mono);font-size:9px">Activar</button>`}
    </div>`).join('');
