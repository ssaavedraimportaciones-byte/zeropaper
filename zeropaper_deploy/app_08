function crearDoc() {
  const nombre = document.getElementById('newDocNombre').value.trim().toUpperCase().replace(/ /g,'_');
  if (!nombre) return;
  if (!deptoActivo.docs.includes(nombre)) {
    deptoActivo.docs.push(nombre);
    localStorage.setItem(K_DEPTOS, JSON.stringify(deptos));
    renderDeptos();
    showToast('📄','Documento agregado', nombre.replace(/_/g,' '));
  }
  document.getElementById('newDocModal').remove();
}

function eliminarDoc(doc) {
  if (!deptoActivo) return;
  deptoActivo.docs = deptoActivo.docs.filter(d=>d!==doc);
  localStorage.setItem(K_DEPTOS, JSON.stringify(deptos));
  renderDeptos();
}

