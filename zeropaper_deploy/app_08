let pollingTimer = null;

async function pollEstados() {
  if (!session?.empresaId || !navigator.onLine) return;
  try {
    const res = await fsList(`empresas/${session.empresaId}/ops`);
    const remoteOps = (res.documents || []).map(parseFs);
    // Filtrar ops propias con estado terminal
    const actualizadas = remoteOps.filter(o =>
      o.uid === session.uid &&
      (o.estado === 'APROBADO' || o.estado === 'RECHAZADO')
    );
    if (!actualizadas.length) return;

    const localOps = await dbGetAll('ops');
    let cambios = false;

    for (const remote of actualizadas) {
      // Buscar local por id o _id
      const local = localOps.find(o =>
        o.id === remote.id || (remote._id && o._id === remote._id)
      );
      if (!local || local.estado === remote.estado) continue;

      local.estado = remote.estado;
      if (remote.logsJson) {
        try { local.logs = JSON.parse(remote.logsJson); } catch(e) {}
      }
      if (remote.motivoRechazo) local.motivoRechazo = remote.motivoRechazo;
      await dbPut('ops', local);
      cambios = true;

      if (remote.estado === 'RECHAZADO') {
        const motivo = local.logs?.slice().reverse().find(l => l.accion === 'RECHAZADO')?.comentario
          || remote.motivoRechazo || '';
        showToast('⚠', `${local.plate}: Rechazada`, motivo.slice(0, 45));
