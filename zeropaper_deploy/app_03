async function sha256(str) {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
}

function emailToUid(email) {
  return email.toLowerCase().replace(/[^a-z0-9]/g,'_').slice(0,40);
}

function genToken() {
  const arr = new Uint8Array(32);
  crypto.getRandomValues(arr);
  return Array.from(arr).map(b => b.toString(16).padStart(2,'0')).join('');
}

function getValidToken() {
  if (!session) return null;
  if (Date.now() > session.expiresAt) { doLogout(); return null; }
  return session.localToken || 'local';
}

function saveSession() {
  localStorage.setItem(K_SESSION, JSON.stringify(session));
}

function loadSession() {
  try {
    const s = localStorage.getItem(K_SESSION);
    if (s) session = JSON.parse(s);
  } catch(e) { session = null; }
}

function doLogout() {
  session = null;
  localStorage.removeItem(K_SESSION);
  document.getElementById('app').style.display = 'none';
  showLogin();
}

function toFsDoc(obj) {
  const fields = {};
  for (const [k,v] of Object.entries(obj)) {
    if (v === null || v === undefined) continue;
    if (typeof v === 'number')  fields[k] = { integerValue: String(Math.round(v)) };
    else if (typeof v === 'boolean') fields[k] = { booleanValue: v };
    else fields[k] = { stringValue: String(v) };
  }
  return { fields };
}

function parseFs(doc) {
  const out = { _id: doc.name?.split('/').pop() };
  for (const [k,v] of Object.entries(doc.fields || {})) {
    if (v.stringValue  !== undefined) out[k] = v.stringValue;
    else if (v.integerValue !== undefined) out[k] = parseInt(v.integerValue);
    else if (v.booleanValue !== undefined) out[k] = v.booleanValue;
  }
  return out;
}

async function fsGet(path) {
  const url = `${FS_BASE()}/${path}?key=${FB.apiKey}`;
  const res = await fetch(url);
  if (!res.ok) throw new Error(res.status);
  return res.json();
}

async function fsList(path) {
  const url = `${FS_BASE()}/${path}?key=${FB.apiKey}&pageSize=500`;
  const res = await fetch(url);
  if (!res.ok) throw new Error(res.status);
  return res.json();
}

async function fsSet(path, data) {
  const url = `${FS_BASE()}/${path}?key=${FB.apiKey}`;
  const res = await fetch(url, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(toFsDoc(data))
  });
  if (!res.ok) throw new Error(res.status);
  return res.json();
}

async function fsPost(path, data) {
  const url = `${FS_BASE()}/${path}?key=${FB.apiKey}`;
  const res = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(toFsDoc(data))
  });
  if (!res.ok) throw new Error(res.status);
  return res.json();
}

async function cargarPerfil(uid) {
  try {
    const doc = await fsGet(`usuarios/${uid}`);
    const p = parseFs(doc);
    return p.email ? p : null;
  } catch(e) { return null; }
}

async function crearEmpresa(empresaNombre) {
  const empresaId = 'emp_' + Date.now().toString(36) + Math.random().toString(36).slice(2,6);
  const codigo = empresaId.slice(4,10).toUpperCase();
  const data = { nombre: empresaNombre, codigo, creadoEn: Date.now(), activa: true };
  await fsSet(`empresas/${empresaId}/perfil/datos`, data);
  await fsSet(`codigoEmpresas/${codigo}`, { empresaId, empresaNombre: empresaNombre });
  return { empresaId, codigo };
}

async function buscarEmpresaPorCodigo(codigo) {
  try {
    const doc = await fsGet(`codigoEmpresas/${codigo.toUpperCase().trim()}`);
    const data = parseFs(doc);
    return data.empresaId ? data : null;
  } catch(e) { return null; }
}

