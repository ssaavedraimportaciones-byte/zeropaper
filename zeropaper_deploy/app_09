        if (navigator.vibrate) navigator.vibrate([200, 100, 200]);
      } else if (remote.estado === 'APROBADO') {
        showToast('✅', `${local.plate}: Aprobada`, 'Operación aprobada');
        if (navigator.vibrate) navigator.vibrate([100]);
      }
    }
    if (cambios) renderHome();
  } catch(e) { /* offline o error de red */ }
}

function startPolling() {
  if (pollingTimer) return;
  pollEstados(); // poll inmediato al iniciar
  pollingTimer = setInterval(() => {
    if (document.visibilityState !== 'hidden') pollEstados();
  }, 90000); // cada 90 segundos
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'visible') pollEstados();
  }, { passive: true });
}

// ══════════════════════════════════════
//  SYNC DEPTOS DESDE FIRESTORE
// ══════════════════════════════════════

async function sincronizarDeptos() {
  if (!session?.empresaId || !navigator.onLine) return;
  try {
    const doc = await fsGet(`empresas/${session.empresaId}/config/deptos`);
    const data = parseFs(doc);
    if (data.deptosJson) {
      const remotos = JSON.parse(data.deptosJson);
      if (Array.isArray(remotos) && remotos.length > 0) {
        localStorage.setItem(K_DEPTOS, JSON.stringify(remotos));
        deptos = remotos;
        const activeId = localStorage.getItem(K_DEPTO);
        deptoActivo = deptos.find(d => d.id === activeId) || deptos[0];
        actualizarSelectorDepto();
      }
    }
  } catch(e) { /* usar deptos locales */ }
}

