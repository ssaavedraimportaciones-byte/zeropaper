});

// ══════════════════════════════════════
//  SUGERENCIAS IA
// ══════════════════════════════════════

async function loadAISuggestions(el, ops) {
  try {
    const knowledge = await getSmartSuggestions();
    if (!knowledge) { el.style.display = 'none'; return; }

    const tips = [];
    const patterns = knowledge.patterns || {};
    const freqPlates = knowledge.frequentPlates || {};

    // Detect peak hours
    const hour = new Date().getHours();
    let peakDocs = [];
    for (const [key, count] of Object.entries(patterns)) {
      if (key.includes(`_h${hour}`) && count > 3) {
        peakDocs.push(key.split('_h')[0].replace(/_/g, ' '));
      }
    }
    if (peakDocs.length) {
      tips.push(`📊 A esta hora sueles registrar: <strong>${peakDocs.slice(0,3).join(', ')}</strong>`);
    }

    // Top frequent plates
    const topPlates = Object.entries(freqPlates).sort((a,b) => b[1] - a[1]).slice(0, 3);
    if (topPlates.length >= 2) {
      tips.push(`🚛 Vehículos frecuentes: <strong>${topPlates.map(([p]) => p).join(', ')}</strong>`);
    }

    // Ops velocity insight
    const today = new Date().toLocaleDateString('es-CL');
    const todayOps = ops.filter(o => o.fecha === today);
    if (todayOps.length > 10) {
      tips.push(`⚡ Ritmo alto hoy: <strong>${todayOps.length} operaciones</strong> registradas`);
    }

    if (!tips.length) { el.style.display = 'none'; return; }

    el.innerHTML = `
      <div style="background:rgba(79,143,247,.06);border:1px solid rgba(79,143,247,.2);border-radius:14px;padding:14px;margin-bottom:12px;">
        <div style="font-weight:700;font-size:12px;color:var(--b);margin-bottom:8px;display:flex;align-items:center;gap:6px;">
          💡 Sugerencias IA
          <span style="font-size:9px;font-weight:600;background:rgba(79,143,247,.15);padding:2px 8px;border-radius:6px;">Aprendido</span>
        </div>
        ${tips.map(t => `<div style="font-size:12px;color:var(--fg2);padding:3px 0;">${t}</div>`).join('')}
      </div>`;
    el.style.display = 'block';
  } catch(e) { el.style.display = 'none'; }
}

// ══════════════════════════════════════
//  INICIO DE APP
// ══════════════════════════════════════

function iniciarApp() {
  document.getElementById('loginScreen').style.display    = 'none';
  document.getElementById('registerScreen').style.display = 'none';
  document.getElementById('app').style.display            = 'flex';
}

async function init() {
  // Tema + font
  const tema = localStorage.getItem(K_TEMA);
  if (tema && tema!=='oscuro') document.documentElement.setAttribute('data-theme', tema);
  const font = localStorage.getItem('zp5_font');
  if (font) document.body.style.fontSize = font+'px';

  // DB
  await initDB();

  // Cargar deptos
  cargarDeptos();

  // Sesión
  loadSession();

  if (session) {
    // Verificar que el token no esté muy expirado
    if (Date.now() > session.expiresAt + 7 * 24 * 3600 * 1000) {
      doLogout(); return;
    }
    iniciarApp();
    await renderHome();
    turnoInicio = localStorage.getItem(K_TURNO);
    if (!turnoInicio) {
      turnoInicio = new Date().toISOString();
      localStorage.setItem(K_TURNO, turnoInicio);
    }
    // Sincronizar deptos y arrancar polling de estados
    sincronizarDeptos();
    startPolling();
  } else {
    showLogin();
  }

  // Events
  checkOnline();
  window.addEventListener('online',  checkOnline);
  window.addEventListener('offline', checkOnline);

  // Enter en login
  document.getElementById('loginPass').addEventListener('keydown', e => {
    if (e.key === 'Enter') doLogin();
  });
  document.getElementById('loginEmail').addEventListener('keydown', e => {
    if (e.key === 'Enter') document.getElementById('loginPass').focus();
  });
}

document.addEventListener('DOMContentLoaded', init);
