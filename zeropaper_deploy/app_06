function estadoBadge(est) {
  const map = {
    PENDIENTE:  ['est-pendiente','⏳ PEND'],
    EN_REVISION:['est-revision', '👁 REVISIÓN'],
    APROBADO:   ['est-aprobado', '✓ APROBADO'],
    RECHAZADO:  ['est-rechazado','✗ RECHAZADO'],
  };
  const [cls, label] = map[est] || map['PENDIENTE'];
  return `<span class="estado-badge ${cls}">${label}</span>`;
}

function opRow(op) {
  const isIn = op.tipo === 'INGRESO';
  const docLabel = (op.docType||'').replace(/_/g,' ');
  const est = op.estado || 'PENDIENTE';
  const borderColor = est==='RECHAZADO' ? 'border-color:rgba(239,68,68,.35)' :
                      est==='APROBADO'  ? 'border-color:rgba(34,197,94,.25)'  : '';
  return `<div class="h-item" onclick="verDetalle('${op.id}')" style="${borderColor}">
    <div class="h-dot ${isIn?'hd-g':'hd-o'}"></div>
    <div class="h-body">
      <div class="h-top" style="flex-wrap:wrap;gap:4px">
        <span class="h-tipo ${isIn?'cg':'co'}">${op.tipo}</span>
        <span class="h-pat">${op.plate||'—'}</span>
        <span class="h-depto">${op.deptoNombre||op.depto||''}</span>
        ${estadoBadge(est)}
      </div>
      <div class="h-meta">${op.fecha} ${op.hora} · ${docLabel}</div>
    </div>
    <span class="h-badge">${(op.fotoIds?.length||0)>1?`📷${op.fotoIds.length}`:op.fotoId?'📷':'📋'}</span>
  </div>`;
}

