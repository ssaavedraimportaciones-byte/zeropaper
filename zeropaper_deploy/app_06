async function renderHistorial(ops_override) {
  const ops = ops_override || await getOpsEmpresa();
  const filtrados = curFiltro==='TODOS' ? ops :
    ops.filter(o => o.tipo===curFiltro || o.depto===curFiltro || o.deptoNombre===curFiltro);
  document.getElementById('histList').innerHTML = filtrados.length ? filtrados.map(opRow).join('') :
    '<div class="empty"><div class="empty-i">🔍</div><div class="empty-t">Sin registros</div></div>';
  const pillsEl = document.getElementById('filterPills');
  const deptoPills = deptos.map(d =>
    `<span class="pill ${curFiltro===d.id?'on':''}" onclick="filtrarH('${d.id}',this)">${d.icon} ${d.nombre}</span>`
  ).join('');
  pillsEl.innerHTML = `
    <span class="pill ${curFiltro==='TODOS'?'on':''}" onclick="filtrarH('TODOS',this)">Todos</span>
    <span class="pill ${curFiltro==='INGRESO'?'on':''}" onclick="filtrarH('INGRESO',this)">↓ Ingreso</span>
    <span class="pill ${curFiltro==='SALIDA'?'on':''}" onclick="filtrarH('SALIDA',this)">↑ Salida</span>
    ${deptoPills}`;
}

function filtrarH(cat) { curFiltro = cat; renderHistorial(); }

async function buscarOps(q) {
  if (!q.trim()) { renderHistorial(); return; }
  const ops = await getOpsEmpresa();
  const t = q.toLowerCase().trim();
  renderHistorial(ops.filter(o => {
    const fields = [
      o.plate, o.folio, o.fecha, o.hora,
      o.docType, o.deptoNombre, o.depto,
      o.operador, o.empresa, o.rut,
      o.obs, o.tipo, o.estado,
      o.destinatario, o.conductor, o.camion,
      o.contenedor, o.guia, o.sello
    ];
    return fields.some(f => (f||'').toLowerCase().includes(t));
  }));
}

