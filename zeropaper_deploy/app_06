async function renderHome() {
  if (!session) return;
  document.getElementById('homeDeptName').textContent = deptoActivo?.nombre || 'Sin departamento';
  // User badge
  const initials = (session.nombre||'?').split(' ').map(n=>n[0]).slice(0,2).join('').toUpperCase();
  document.getElementById('homeUserBadge').innerHTML = `
    <div class="user-badge">
      <div class="user-avatar">${initials}</div>
      <div><div class="user-name">${session.nombre||session.email}</div>
      <div class="user-empresa">${session.empresaNombre||''} · ${session.rol||'operador'}</div></div>
    </div>`;
  const ops = await getOpsEmpresa();
  const today = new Date().toLocaleDateString('es-CL');
  const hoy = ops.filter(o => o.fecha===today);
  document.getElementById('homeCount').textContent = hoy.length;

  // ── Alerta de operaciones rechazadas ──
  const rechazadas = ops.filter(o => o.estado==='RECHAZADO' && o.uid===session.uid).slice(0,3);
  const alertEl = document.getElementById('rechazoAlert');
  if (rechazadas.length && alertEl) {
    alertEl.innerHTML = `
      <div class="rechazo-alert">
        <div class="rechazo-alert-title">⚠️ ${rechazadas.length} operación${rechazadas.length>1?'es':''} rechazada${rechazadas.length>1?'s':''}</div>
        ${rechazadas.map(o => {
          const motivo = o.logs?.slice().reverse().find(l=>l.accion==='RECHAZADO')?.comentario || 'Sin motivo';
          return `<div class="rechazo-item">
            <span><strong>${o.plate}</strong> · ${(o.docType||'').replace(/_/g,' ')}</span>
            <span style="font-size:11px;color:#f87171">${motivo}</span>
          </div>`;
        }).join('')}
      </div>`;
    alertEl.style.display = 'block';
  } else if (alertEl) alertEl.style.display = 'none';

  // ── Detección de anomalías ──
  const anomaliaEl = document.getElementById('anomaliaAlert');
  if (anomaliaEl) {
    const anomalias = [];
    // Vehículos con más de 1 ingreso pendiente sin salida
    const recientes48h = ops.filter(o => (Date.now() - (o.ts||0)) < 172800000 && o.plate);
    const placasMap = {};
    recientes48h.sort((a,b) => a.ts - b.ts).forEach(op => {
      if (!placasMap[op.plate]) placasMap[op.plate] = 0;
      if (op.tipo === 'INGRESO') placasMap[op.plate]++;
      else if (op.tipo === 'SALIDA') placasMap[op.plate] = Math.max(0, placasMap[op.plate] - 1);
    });
    const atrapados = Object.entries(placasMap).filter(([,n]) => n > 1).map(([p]) => p);
    if (atrapados.length) anomalias.push(`🔴 ${atrapados.length} patente${atrapados.length>1?'s':''} con múltiples ingresos sin salida: ${atrapados.slice(0,3).join(', ')}`);

    // Últimas 10 ops sin foto
    const sinFoto = ops.slice(0,10).filter(o => !o.fotoId && !(o.fotoIds?.length));
    if (sinFoto.length >= 5) anomalias.push(`📷 ${sinFoto.length} de las últimas 10 operaciones sin foto de documento`);

    if (anomalias.length) {
      anomaliaEl.innerHTML = `<div class="rechazo-alert" style="border-color:rgba(251,191,36,.3);background:rgba(251,191,36,.07)">
        <div class="rechazo-alert-title" style="color:#fbbf24">⚡ Anomalías detectadas</div>
        ${anomalias.map(a => `<div class="rechazo-item" style="color:#fbbf24">${a}</div>`).join('')}
      </div>`;
      anomaliaEl.style.display = 'block';
    } else anomaliaEl.style.display = 'none';
  }

  // ── Sugerencias IA ──
  const sugEl = document.getElementById('aiSuggestions');
  if (sugEl && navigator.onLine) {
    loadAISuggestions(sugEl, ops);
  }

  const recents = ops.slice(0,5);
  const el = document.getElementById('homeList');
  el.innerHTML = recents.length ? recents.map(opRow).join('') :
    '<div class="empty"><div class="empty-i">📋</div><div class="empty-t">Sin operaciones aún</div></div>';
}

