async function verDetalle(id) {
  const ops = await dbGetAll('ops');
  const op = ops.find(o=>o.id===id);
  if (!op) return;
  const isIn = op.tipo==='INGRESO';
  let fotoHtml = '<div style="background:var(--bg3);border-radius:12px;padding:24px;text-align:center;margin-bottom:14px;color:var(--mu);font-family:var(--mono);font-size:12px">📷 Sin fotos adjuntas</div>';
  // Soporte multi-foto: fotoIds[] tiene prioridad, sino usa fotoId legacy
  const fotoIds = op.fotoIds?.length ? op.fotoIds : (op.fotoId ? [op.fotoId] : []);
