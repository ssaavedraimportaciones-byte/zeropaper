  const plate = document.getElementById(pre+'Plate').value.trim().toUpperCase();
  const folio = document.getElementById(pre+'Folio').value.trim();
  const docT  = document.getElementById(pre+'DocType').value;
  const obs   = document.getElementById(pre+'Obs').value.trim();

  if (!plate) { showToast('⚠','Falta patente','Ingresa la patente del vehículo'); return; }

  const btn = document.getElementById(isIn?'inBtn':'outBtn');
  btn.textContent = '⏳ Guardando...';
  btn.disabled = true;

  // ── Validar folio duplicado ──
  if (folio) {
    const opsPrevias = await getOpsEmpresa();
    const dup = opsPrevias.find(o => o.folio && o.folio === folio);
    if (dup) {
      const ok = confirm(`⚠ Folio "${folio}" ya fue registrado\n${dup.plate} · ${(dup.docType||'').replace(/_/g,' ')} · ${dup.fecha}\n¿Continuar de todos modos?`);
      if (!ok) {
        btn.textContent = isIn ? '✓ Confirmar Ingreso' : '✓ Confirmar Salida';
        btn.disabled = false;
        return;
      }
    }
  }

  const now = new Date();
  const op = {
    id:          'op_' + Date.now() + '_' + Math.random().toString(36).slice(2,5),
    tipo:        isIn ? 'INGRESO' : 'SALIDA',
    plate, folio, docType: docT, obs,
    depto:       deptoActivo?.id || '',
    deptoNombre: deptoActivo?.nombre || '',
    fecha:       now.toLocaleDateString('es-CL'),
    hora:        now.toLocaleTimeString('es-CL',{hour:'2-digit',minute:'2-digit'}),
    ts:          now.getTime(),
    uid:         session.uid,
    empresaId:   session.empresaId,
    empresaNombre: session.empresaNombre,
    operador:    session.nombre,
    fotoId:      null,
    fotoIds:     [],
    syncStatus:  'pending',
    estado:      'PENDIENTE',
    logs:        [{ accion:'CREADO', usuario: session.nombre, ts: now.getTime(), comentario:'' }]
  };

  const fotos = fotosDir[dir] || [];
  if (fotos.length > 0) {
    op.fotoIds = [];
    for (let i = 0; i < fotos.length; i++) {
      const fId = 'foto_' + op.id + '_' + i;
      op.fotoIds.push(fId);
      await dbPut('fotos', { id: fId, data: fotos[i].data, ts: op.ts });
    }
    op.fotoId = op.fotoIds[0]; // compatibilidad hacia atrás
  }

  await dbPut('ops', op);
  sincronizarFirebase(op); // async, no esperar

  btn.textContent = isIn ? '✓ Confirmar Ingreso' : '✓ Confirmar Salida';
  btn.disabled = false;
  fotosDir[dir] = [];

  showToast(isIn?'📥':'📤', isIn?'Ingreso registrado':'Salida registrada', `${plate} · ${docT.replace(/_/g,' ')}`);

  // Register learning patterns
  registerLearning('plate_frequency', { plate });
  registerLearning('doc_pattern', { docType: docT, depto: deptoActivo?.id });

  // QR de seguimiento solo en INGRESO
  if (isIn && session?.empresaId) {
    const qrUrl = `${location.origin}/seguimiento?e=${session.empresaId}&p=${encodeURIComponent(plate)}`;
    setTimeout(() => showQRModal(plate, qrUrl), 700);
  } else {
    setTimeout(() => goTo('home'), 600);
  }
}

