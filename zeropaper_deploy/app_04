function initDB() {
  return new Promise((res, rej) => {
    const req = indexedDB.open(DB_NAME, DB_VER);
    req.onupgradeneeded = e => {
      const d = e.target.result;
      if (!d.objectStoreNames.contains('ops')) {
        const s = d.createObjectStore('ops', { keyPath:'id' });
        s.createIndex('tipo','tipo',{unique:false});
        s.createIndex('ts','ts',{unique:false});
        s.createIndex('empresaId','empresaId',{unique:false});
      }
      if (!d.objectStoreNames.contains('fotos'))
        d.createObjectStore('fotos', { keyPath:'id' });
    };
    req.onsuccess = e => { db = e.target.result; res(); };
    req.onerror   = e => rej(e);
  });
}

function dbPut(store, obj) {
  return new Promise((res,rej) => {
    const tx = db.transaction(store,'readwrite');
    const req = tx.objectStore(store).put(obj);
    req.onsuccess = () => res(req.result);
    req.onerror   = () => rej(req.error);
  });
}

function dbGet(store, key) {
  return new Promise((res,rej) => {
    const tx = db.transaction(store,'readonly');
    const req = tx.objectStore(store).get(key);
    req.onsuccess = () => res(req.result);
    req.onerror   = () => rej(req.error);
  });
}

function dbGetAll(store) {
  return new Promise((res,rej) => {
    const tx = db.transaction(store,'readonly');
    const req = tx.objectStore(store).getAll();
    req.onsuccess = () => res(req.result);
    req.onerror   = () => rej(req.error);
  });
}

function dbDelete(store, key) {
  return new Promise((res,rej) => {
    const tx = db.transaction(store,'readwrite');
    const req = tx.objectStore(store).delete(key);
    req.onsuccess = () => res();
    req.onerror   = () => rej(req.error);
  });
}

async function getOpsEmpresa() {
  if (!session) return [];
  const all = await dbGetAll('ops');
  return all.filter(o => o.empresaId === session.empresaId).sort((a,b) => b.ts - a.ts);
}

