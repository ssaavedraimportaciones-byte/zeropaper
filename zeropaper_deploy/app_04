function renderFotosZone(dir) {
  const zoneId = dir==='in' ? 'fotosZoneIn' : 'fotosZoneOut';
  const zone = document.getElementById(zoneId);
  if (!zone) return;
  const fotos = fotosDir[dir];
  const thumbsHtml = fotos.map((f, i) => `
    <div class="foto-thumb" onclick="verFotoCaptura('${dir}',${i})" style="cursor:pointer">
      <img src="${f.data}" alt="doc ${i+1}">
      <button class="foto-remove" onclick="event.stopPropagation();removeFoto('${dir}',${i})">✕</button>
      <span class="foto-num">${i+1}</span>
    </div>`).join('');
  const camId = dir==='in' ? 'camIn' : 'camOut';
  zone.innerHTML = `
    ${fotos.length > 0 ? `<div class="fotos-grid">${thumbsHtml}</div>` : ''}
    <div class="foto-add-btn" onclick="document.getElementById('${camId}').click()">
      📷 ${fotos.length === 0 ? 'Agregar foto del documento' : 'Agregar otra foto'}
      ${fotos.length > 0 ? `<span class="foto-count">${fotos.length} foto${fotos.length>1?'s':''}</span>` : ''}
    </div>
    ${fotos.length > 0 ? `
    <button class="btn-prime btn-green" style="margin-top:10px;padding:14px;font-size:14px;display:flex;align-items:center;justify-content:center;gap:8px;" 
      id="ocrBtn_${dir}" onclick="runOCR('${dir}')">
      <span>🧠</span> <span>Leer documento con IA</span>
    </button>
    <div id="ocrResult_${dir}" style="display:none;margin-top:10px;"></div>
    ` : ''}`;
}

