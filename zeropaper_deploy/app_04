}

async function doLogin() {
  const email = document.getElementById('loginEmail').value.trim().toLowerCase();
  const pass  = document.getElementById('loginPass').value;
  const errEl = document.getElementById('loginErr');
  errEl.textContent = '';
  if (!email || !pass) { errEl.textContent = 'Completa todos los campos'; return; }

  const btn = document.querySelector('#loginScreen .auth-btn');
  btn.textContent = '⏳ Ingresando...'; btn.disabled = true;

  try {
    const uid  = emailToUid(email);
    const hash = await sha256(email + '::' + pass);

    const doc = await fsGet(`usuarios/${uid}`);
    const perfil = parseFs(doc);

    if (!perfil.passHash || perfil.passHash !== hash) {
      errEl.textContent = 'Correo o contraseña incorrectos';
      btn.textContent = 'Entrar →'; btn.disabled = false;
      return;
    }

    session = {
      uid, email,
      localToken:  genToken(),
      expiresAt:   Date.now() + 12 * 3600 * 1000, // 12 horas
      nombre:      perfil.nombre || email.split('@')[0],
      empresaId:   perfil.empresaId,
      empresaNombre: perfil.empresaNombre,
      rol:         perfil.rol || 'operador'
    };
    saveSession();
    // Actualizar último login en operadores
    try {
      await fsSet(`empresas/${perfil.empresaId}/operadores/${uid}`, {
        nombre: perfil.nombre || email.split('@')[0],
        email, rol: perfil.rol || 'operador',
        creadoEn: perfil.creadoEn || Date.now()
      });
    } catch(e) {}
    iniciarApp();
  } catch(e) {
    errEl.textContent = 'Correo o contraseña incorrectos';
  }
  btn.textContent = 'Entrar →'; btn.disabled = false;
}

async function doRegister() {
  const nombre    = document.getElementById('regNombre').value.trim();
  const email     = document.getElementById('regEmail').value.trim().toLowerCase();
  const pass      = document.getElementById('regPass').value;
  const codigo    = document.getElementById('regCodigo').value.trim().toUpperCase();
  const empNombre = document.getElementById('regEmpresa').value.trim();
  const errEl     = document.getElementById('registerErr');
  errEl.textContent = '';

  if (!nombre || !email || pass.length < 6) {
    errEl.textContent = 'Completa nombre, correo y contraseña (mín. 6 caracteres)'; return;
  }

  const btn = document.querySelector('#registerScreen .auth-btn');
  btn.textContent = '⏳ Creando cuenta...'; btn.disabled = true;

  try {
    const uid  = emailToUid(email);
    const hash = await sha256(email + '::' + pass);

    // Verificar si el correo ya existe
    try {
      const existing = await fsGet(`usuarios/${uid}`);
      const ex = parseFs(existing);
      if (ex.passHash) {
        errEl.textContent = 'Este correo ya está registrado. Inicia sesión.';
        btn.textContent = 'Crear cuenta →'; btn.disabled = false;
        return;
      }
    } catch(e) { /* no existe, OK */ }

    let empresaId, empresaNombre;

    if (codigo) {
      const emp = await buscarEmpresaPorCodigo(codigo);
      if (!emp) {
        errEl.textContent = 'Código de empresa no válido';
        btn.textContent = 'Crear cuenta →'; btn.disabled = false;
        return;
      }
      empresaId = emp.empresaId;
      empresaNombre = emp.empresaNombre;
    } else {
      if (!empNombre) {
        errEl.textContent = 'Ingresa el nombre de tu empresa o un código de empresa';
        btn.textContent = 'Crear cuenta →'; btn.disabled = false;
        return;
      }
      const emp = await crearEmpresa(empNombre);
      empresaId = emp.empresaId;
      empresaNombre = empNombre;
    }

    const rol = codigo ? 'operador' : 'admin';

    await fsSet(`usuarios/${uid}`, {
      nombre, email, passHash: hash, empresaId, empresaNombre,
      rol, creadoEn: Date.now()
    });

    await fsSet(`empresas/${empresaId}/operadores/${uid}`, {
      nombre, email, rol, creadoEn: Date.now()
    });

    session = {
      uid, email,
      localToken:   genToken(),
      expiresAt:    Date.now() + 12 * 3600 * 1000,
      nombre, empresaId, empresaNombre, rol
    };
    saveSession();
    iniciarApp();
  } catch(e) {
    errEl.textContent = 'Error al crear cuenta. Intenta nuevamente.';
  }
  btn.textContent = 'Crear cuenta →'; btn.disabled = false;
}

