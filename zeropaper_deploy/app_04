const VIEWS = ['home','ingreso','salida','historial','turno','deptos','temas','config'];
const TABS  = ['home','historial','turno','deptos','config'];

function goTo(name) {
  VIEWS.forEach(v => {
    document.getElementById('v'+cap(v))?.classList.remove('active');
    if (TABS.includes(v)) document.getElementById('t-'+v)?.classList.remove('on');
  });
  document.getElementById('v'+cap(name))?.classList.add('active');
  if (TABS.includes(name)) document.getElementById('t-'+name)?.classList.add('on');
  document.getElementById('mainScroll').scrollTop = 0;
  if (name==='home')      renderHome();
  if (name==='historial') renderHistorial();
  if (name==='turno')     renderTurno();
  if (name==='deptos')    renderDeptos();
  if (name==='ingreso')   prepForm('in');
  if (name==='salida')    prepForm('out');
  if (name==='config')    cargarConfig();
  if (name==='temas')     cargarTema();
}

function cap(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

