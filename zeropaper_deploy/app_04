function cargarDeptos() {
  const saved = localStorage.getItem(K_DEPTOS);
  deptos = saved ? JSON.parse(saved) : JSON.parse(JSON.stringify(DEPTOS_DEFAULT));
  const deptoId = localStorage.getItem(K_DEPTO) || deptos[0]?.id;
  deptoActivo = deptos.find(d => d.id === deptoId) || deptos[0];
  actualizarSelectorDepto();
}

function actualizarSelectorDepto() {
  const sel = document.getElementById('deptoSel');
  sel.innerHTML = deptos.map(d =>
    `<option value="${d.id}" ${d.id===deptoActivo?.id?'selected':''}>${d.icon} ${d.nombre}</option>`
  ).join('');
}

function cambiarDepto(id) {
  deptoActivo = deptos.find(d => d.id === id);
  if (deptoActivo) {
    localStorage.setItem(K_DEPTO, id);
    renderHome();
    showToast('🏗', 'Departamento', deptoActivo.nombre);
  }
}

function getDocTypes() {
  return deptoActivo?.docs || [];
}

function prepForm(dir) {
  const docs = getDocTypes();
  const selId = dir==='in' ? 'inDocType' : 'outDocType';
  const sel = document.getElementById(selId);
  sel.innerHTML = docs.map(d => `<option value="${d}">${d.replace(/_/g,' ')}</option>`).join('');
  ['Plate','Folio','Obs'].forEach(f => {
    const el = document.getElementById((dir==='in'?'in':'out')+f);
    if (el) el.value = '';
  });
  fotosDir[dir] = [];
  renderFotosZone(dir);
}

