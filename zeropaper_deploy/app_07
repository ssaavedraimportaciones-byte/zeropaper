async function renderTurno() {
  if (!session) return;

  // Header turno
  const initials = (session.nombre||'?').split(' ').map(n=>n[0]).slice(0,2).join('').toUpperCase();
  document.getElementById('turnoNombreDisplay').innerHTML = `<div style="display:flex;align-items:center;gap:10px"><div class="user-avatar">${initials}</div><div class="turno-op-name">${session.nombre||session.email}</div></div>`;
  document.getElementById('turnoEmpresaDisplay').textContent = session.empresaNombre || '';

  turnoInicio = localStorage.getItem(K_TURNO);
  if (!turnoInicio) {
    turnoInicio = new Date().toISOString();
    localStorage.setItem(K_TURNO, turnoInicio);
  }
  const inicioDate = new Date(turnoInicio);
  const ahora = new Date();
  const diffMs = ahora - inicioDate;
  const diffH = Math.floor(diffMs / 3600000);
  const diffM = Math.floor((diffMs % 3600000) / 60000);
  document.getElementById('turnoTimeDisplay').textContent =
    `Turno iniciado: ${inicioDate.toLocaleTimeString('es-CL',{hour:'2-digit',minute:'2-digit'})} · Duración: ${diffH}h ${diffM}m`;
  document.getElementById('turnoInicioLabel').textContent = inicioDate.toLocaleDateString('es-CL');

  const ops = await getOpsEmpresa();
  const today = new Date().toLocaleDateString('es-CL');
  const hoy   = ops.filter(o => o.fecha === today);
  const ingresos = hoy.filter(o => o.tipo === 'INGRESO');
  const salidas  = hoy.filter(o => o.tipo === 'SALIDA');
  const conFoto  = hoy.filter(o => o.fotoId || o.fotoIds?.length);

  // Vehículos en planta = ingresos sin salida correspondiente (última 48h)
  const limite48h = Date.now() - 48 * 3600 * 1000;
  const recentOps = ops.filter(o => o.ts > limite48h && o.plate && o.plate !== '—');
  const inPlanta  = calcularEnPlanta(recentOps);

  document.getElementById('tsI').textContent = ingresos.length;
  document.getElementById('tsS').textContent = salidas.length;
  document.getElementById('tsP').textContent = inPlanta.length;
  document.getElementById('tsF').textContent = conFoto.length;

  // Lista pendientes
  const pendEl = document.getElementById('pendientesList');
  if (inPlanta.length === 0) {
    pendEl.innerHTML = '<div class="empty"><div class="empty-i">✅</div><div class="empty-t">No hay vehículos en planta</div></div>';
  } else {
    pendEl.innerHTML = inPlanta.map(op => {
      const tiempoEnPlanta = calcularTiempoTranscurrido(op.ts);
      return `<div class="pendiente-item">
        <span class="pendiente-icon">🚛</span>
        <div class="pendiente-body">
          <div class="pendiente-plate">${op.plate}</div>
          <div class="pendiente-meta">${(op.docType||'').replace(/_/g,' ')} · ${op.deptoNombre||''}</div>
        </div>
        <div class="pendiente-time">${tiempoEnPlanta}</div>
      </div>`;
    }).join('');
  }

  // Portal link
  const baseUrl = window.location.origin;
  const portalUrl = `${baseUrl}/seguimiento?e=${session.empresaId}`;
  document.getElementById('portalLink').textContent = portalUrl;
}

function calcularEnPlanta(ops) {
  const placas = {};
  ops.sort((a,b) => a.ts - b.ts).forEach(op => {
    if (!placas[op.plate]) placas[op.plate] = { ingresos: [], salidas: [] };
    if (op.tipo === 'INGRESO') placas[op.plate].ingresos.push(op);
    else placas[op.plate].salidas.push(op);
  });
  const enPlanta = [];
  for (const [placa, data] of Object.entries(placas)) {
    let pendientes = data.ingresos.length - data.salidas.length;
    if (pendientes > 0) {
      // El último ingreso sin salida
      const ings = data.ingresos.sort((a,b)=>b.ts-a.ts);
      enPlanta.push(ings[0]);
    }
  }
  return enPlanta.sort((a,b) => a.ts - b.ts);
}

function calcularTiempoTranscurrido(ts) {
  const diff = Date.now() - ts;
  const h = Math.floor(diff / 3600000);
  const m = Math.floor((diff % 3600000) / 60000);
  if (h > 0) return `${h}h ${m}m`;
  return `${m}m`;
}

async function cerrarTurno() {
  if (!session) return;
  const nota = document.getElementById('turnoNota').value.trim();
  const ops  = await getOpsEmpresa();
  const today = new Date().toLocaleDateString('es-CL');
  const hoyOps = ops.filter(o => o.fecha === today);
  const limite48h = Date.now() - 48 * 3600 * 1000;
  const recentOps = ops.filter(o => o.ts > limite48h && o.plate && o.plate !== '—');
  const enPlanta  = calcularEnPlanta(recentOps);

  const turno = {
    empresaId:     session.empresaId,
    operadorUid:   session.uid,
    operadorNombre:session.nombre,
    inicioTs:      new Date(turnoInicio).getTime(),
    finTs:         Date.now(),
    totalOps:      hoyOps.length,
    enPlantaCount: enPlanta.length,
    enPlantaPlacas:enPlanta.map(o=>o.plate).join(','),
    nota,
    fecha:         today
  };

  try {
    await fsPost(`empresas/${session.empresaId}/turnos`, turno);
    localStorage.removeItem(K_TURNO);
    turnoInicio = null;
    showToast('✅','Turno cerrado','Traspaso registrado en la nube');
    setTimeout(() => renderTurno(), 500);
  } catch(e) {
    showToast('⚠','Sin conexión','Turno guardado localmente');
    localStorage.removeItem(K_TURNO);
    turnoInicio = null;
    setTimeout(() => renderTurno(), 500);
  }
}

function copiarLink() {
  const url = document.getElementById('portalLink').textContent;
  if (navigator.clipboard) {
    navigator.clipboard.writeText(url).then(() => showToast('📋','Link copiado','Envíalo a tu cliente'));
  } else {
    const ta = document.createElement('textarea');
    ta.value = url;
    document.body.appendChild(ta);
    ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('📋','Link copiado','Envíalo a tu cliente');
  }
}

