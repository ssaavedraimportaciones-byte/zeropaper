    </div>
    ${fotoHtml}
    <div class="modal-row"><span class="modal-lbl">ESTADO</span>${estadoBadge(op.estado||'PENDIENTE')}</div>
    <div class="modal-row"><span class="modal-lbl">TIPO</span><span class="badge" style="background:${isIn?'rgba(74,124,89,.2)':'rgba(255,109,0,.2)'};color:${colorVar}">${op.tipo}</span></div>
    <div class="modal-row"><span class="modal-lbl">DEPTO</span><span class="modal-val">${op.deptoNombre||op.depto||'—'}</span></div>
    <div class="modal-row"><span class="modal-lbl">PATENTE</span><span class="modal-val">${op.plate||'—'}</span></div>
    <div class="modal-row"><span class="modal-lbl">DOCUMENTO</span><span class="modal-val">${(op.docType||'—').replace(/_/g,' ')}</span></div>
    <div class="modal-row"><span class="modal-lbl">FOLIO</span><span class="modal-val">${op.folio||'—'}</span></div>
    <div class="modal-row"><span class="modal-lbl">FECHA</span><span class="modal-val">${op.fecha} ${op.hora}</span></div>
    <div class="modal-row"><span class="modal-lbl">OPERADOR</span><span class="modal-val">${op.operador||'—'}</span></div>
    <div class="modal-row"><span class="modal-lbl">OBS</span><span class="modal-val">${op.obs||'—'}</span></div>
    <div class="modal-row"><span class="modal-lbl">SYNC</span><span class="modal-val">${op.syncStatus==='synced'?'✅ Sincronizado':'⏳ Pendiente'}</span></div>
    ${(op.logs||[]).length > 0 ? `
    <div style="margin-top:12px;padding-top:10px;border-top:1px solid var(--brd)">
      <div class="modal-lbl" style="margin-bottom:8px">TRAZABILIDAD</div>
      <div class="log-list">
        ${(op.logs||[]).map(l => {
          const dotCls = l.accion==='CREADO'?'log-ld-c':l.accion==='APROBADO'?'log-ld-a':l.accion==='RECHAZADO'?'log-ld-r':'log-ld-v';
          const d = new Date(l.ts);
          const ts = d.toLocaleDateString('es-CL')+' '+d.toLocaleTimeString('es-CL',{hour:'2-digit',minute:'2-digit'});
          return `<div class="log-item">
            <div class="log-dot ${dotCls}"></div>
            <div>
              <span style="font-weight:700;font-size:12px">${l.accion}</span>
              <span style="color:var(--mu);font-size:12px"> · ${l.usuario||'—'}</span>
              ${l.comentario?`<span style="color:#f87171;font-size:11px"> · "${l.comentario}"</span>`:''}
              <div class="log-ts">${ts}</div>
            </div>
          </div>`;
        }).join('')}
      </div>
    </div>` : ''}
    <button class="btn-prime btn-gray" style="margin-top:14px" onclick="document.getElementById('opModal').remove()">Cerrar</button>
  </div>`;
  document.body.appendChild(modal);
  modal.addEventListener('click', e => { if(e.target===modal) modal.remove(); });
}

